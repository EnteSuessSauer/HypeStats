<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hypestats.controller.PlayerLookupController"
            styleClass="card">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>
    
    <top>
        <VBox spacing="10">
            <Label text="Player Search" styleClass="section-header"/>
            <HBox spacing="10">
                <TextField fx:id="usernameField" promptText="Enter Minecraft username" HBox.hgrow="ALWAYS"/>
                <Button fx:id="searchButton" text="Search" styleClass="primary-button" onAction="#searchPlayer"/>
                <Button fx:id="clearButton" text="Clear" onAction="#clearResults"/>
            </HBox>
            <ProgressBar fx:id="progressBar" visible="false" prefWidth="Infinity"/>
            <Label fx:id="errorLabel" styleClass="status-stopped" visible="false" wrapText="true"/>
        </VBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" visible="false" fx:id="resultsPane">
            <VBox spacing="15">
                <padding>
                    <Insets top="15" right="0" bottom="0" left="0"/>
                </padding>
                
                <!-- Player header -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ImageView fx:id="playerHead" fitWidth="64" fitHeight="64" preserveRatio="true"/>
                    <VBox spacing="2">
                        <HBox spacing="5" alignment="CENTER_LEFT">
                            <Label fx:id="rankLabel" styleClass="text-AQUA" visible="false"/>
                            <Label fx:id="usernameLabel" styleClass="header-label"/>
                            <Label fx:id="guildTagLabel" styleClass="guild-tag" visible="false"/>
                        </HBox>
                        <Label fx:id="levelLabel" styleClass="level-display"/>
                        <Label fx:id="statusLabel" styleClass="status-label" visible="false"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox fx:id="socialLinksContainer" spacing="8" alignment="CENTER_RIGHT" styleClass="social-links"/>
                </HBox>
                
                <!-- Top Stats Section -->
                <TitledPane text="Top Stats" expanded="true">
                    <VBox fx:id="topStatsContainer" styleClass="top-stats-container" spacing="5">
                        <Label text="No exceptional stats to display" styleClass="stat-average"/>
                    </VBox>
                </TitledPane>
                
                <!-- Network Stats -->
                <TitledPane text="Network Stats" expanded="true">
                    <GridPane styleClass="stats-grid" hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>
                        
                        <!-- Row 1 -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Network Level" styleClass="stat-label"/>
                            <Label fx:id="networkLevelLabel" styleClass="stat-value" text="0"/>
                        </VBox>
                        
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Karma" styleClass="stat-label"/>
                            <Label fx:id="karmaLabel" styleClass="stat-value" text="0"/>
                        </VBox>
                        
                        <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="Achievement Points" styleClass="stat-label"/>
                            <HBox spacing="3" alignment="CENTER_LEFT">
                                <Label fx:id="achievementPointsLabel" styleClass="stat-value" text="0"/>
                                <Label text="(" styleClass="stat-value-suffix"/>
                                <Label fx:id="achievementCompletionLabel" styleClass="stat-value-suffix" text="0%"/>
                                <Label text=")" styleClass="stat-value-suffix"/>
                            </HBox>
                        </VBox>
                        
                        <VBox styleClass="stat-card" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label text="Account Age" styleClass="stat-label"/>
                            <Label fx:id="accountAgeLabel" styleClass="stat-value" text="0 days"/>
                        </VBox>
                        
                        <!-- Row 2 -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Playtime" styleClass="stat-label"/>
                            <Label fx:id="playtimeLabel" styleClass="stat-value" text="Unknown"/>
                        </VBox>
                    </GridPane>
                </TitledPane>
                
                <!-- Guild Information -->
